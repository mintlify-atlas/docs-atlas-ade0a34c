  "keyFeatures": [
    "Type-safe URL query string state management for SolidJS",
    "Reactive createQueryState and createQueryStates primitives",
    "Rich set of built-in parsers (string, integer, boolean, date, enum, array)",
    "Throttle and debounce URL update rate limiting",
    "History push/replace control and scroll-to-top support",
    "NuqsAdapter context provider for SPA integration",
    "Custom parser factory via createParser and createMultiParser",
    "clearOnDefault to keep URLs clean when using default values"
  ],
  "publicApiSurface": [
    "createQueryState(key, options)",
    "createQueryStates(keyMap, options)",
    "NuqsAdapter",
    "parseAsString",
    "parseAsInteger",
    "parseAsIndex",
    "parseAsFloat",
    "parseAsHex",
    "parseAsBoolean",
    "parseAsTimestamp",
    "parseAsIsoDateTime",
    "parseAsIsoDate",
    "parseAsStringLiteral(validValues)",
    "parseAsStringEnum(validValues)",
    "parseAsNumberLiteral(validValues)",
    "parseAsArrayOf(itemParser, separator?)",
    "createParser(parser)",
    "createMultiParser(parser)",
    "throttle(timeMs)",
    "debounce(timeMs)",
    "inferParserType<Input>"
  ]
}
